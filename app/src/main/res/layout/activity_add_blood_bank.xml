<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F2F2"
    android:fitsSystemWindows="true">

    <!-- Top Bar -->
    <RelativeLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#F2F2F2"
        android:paddingHorizontal="16dp">

        <ImageView
            android:id="@+id/back_button"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_arrow_back"
            android:padding="4dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            app:tint="#800000" />

        <TextView
            android:id="@+id/tvBankFormTitle_Secondary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Blood Bank Informations"
            android:textColor="#800000"
            android:textSize="17sp"
            android:textStyle="bold" />

    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/toolbar"
        android:clipToPadding="false"
        android:paddingBottom="100dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="16dp">

            <!-- General Information Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="General Information"
                        android:textColor="#1A1A1A"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="20dp" />

                    <!-- Facility Name -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="FACILITY NAME"
                        android:textColor="#800000"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05"
                        android:layout_marginBottom="6dp" />
                    <EditText
                        android:id="@+id/etBankName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_field_input"
                        android:hint="e.g. Dhaka Central Blood Bank"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="14dp"
                        android:textColor="#1A1A1A"
                        android:textSize="15sp"
                        android:layout_marginBottom="16dp" />

                    <!-- Phone Number -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PHONE NUMBER"
                        android:textColor="#800000"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05"
                        android:layout_marginBottom="6dp" />
                    <EditText
                        android:id="@+id/etBankPhone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_field_input"
                        android:hint="+880 2-XXXXXXX"
                        android:inputType="phone"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="14dp"
                        android:textColor="#1A1A1A"
                        android:textSize="15sp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Location Details Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Location Details"
                        android:textColor="#1A1A1A"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="20dp" />

                    <!-- Address -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ADDRESS"
                        android:textColor="#800000"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05"
                        android:layout_marginBottom="6dp" />
                    <EditText
                        android:id="@+id/etBankAddress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_field_input"
                        android:hint="City or Full Address"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="14dp"
                        android:textColor="#1A1A1A"
                        android:textSize="15sp"
                        android:minLines="2"
                        android:gravity="top|start"
                        android:layout_marginBottom="16dp" />

                    <!-- Lat & Lon row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginEnd="10dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="LATITUDE"
                                android:textColor="#800000"
                                android:textSize="9sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.05"
                                android:layout_marginBottom="6dp" />
                            <EditText
                                android:id="@+id/etLat"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@drawable/bg_field_input"
                                android:hint="23.7261"
                                android:inputType="numberDecimal|numberSigned"
                                android:paddingHorizontal="14dp"
                                android:paddingVertical="14dp"
                                android:textColor="#1A1A1A"
                                android:textSize="15sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="LONGITUDE"
                                android:textColor="#800000"
                                android:textSize="9sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.05"
                                android:layout_marginBottom="6dp" />
                            <EditText
                                android:id="@+id/etLon"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@drawable/bg_field_input"
                                android:hint="90.3976"
                                android:inputType="numberDecimal|numberSigned"
                                android:paddingHorizontal="14dp"
                                android:paddingVertical="14dp"
                                android:textColor="#1A1A1A"
                                android:textSize="15sp" />
                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Inventory Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="bottom"
                        android:layout_marginBottom="20dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Inventory Units"
                            android:textColor="#1A1A1A"
                            android:textSize="20sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_marginBottom="2dp"
                            android:text="(in units)"
                            android:textColor="#757575"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Row 1: A+ and A- -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:background="@drawable/bg_inventory_card"
                            android:padding="16dp"
                            android:gravity="center"
                            android:layout_marginEnd="6dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="A+"
                                android:textColor="#800000"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                            <EditText
                                android:id="@+id/etAPos"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:background="@drawable/bg_field_input"
                                android:gravity="center"
                                android:inputType="number"
                                android:padding="8dp"
                                android:text="0"
                                android:textColor="#1A1A1A"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:background="@drawable/bg_inventory_card"
                            android:padding="16dp"
                            android:gravity="center"
                            android:layout_marginStart="6dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="A-"
                                android:textColor="#800000"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                            <EditText
                                android:id="@+id/etANeg"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:background="@drawable/bg_field_input"
                                android:gravity="center"
                                android:inputType="number"
                                android:padding="8dp"
                                android:text="0"
                                android:textColor="#1A1A1A"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                    </LinearLayout>

                    <!-- Row 2: B+ and B- -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:background="@drawable/bg_inventory_card"
                            android:padding="16dp"
                            android:gravity="center"
                            android:layout_marginEnd="6dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="B+"
                                android:textColor="#800000"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                            <EditText
                                android:id="@+id/etBPos"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:background="@drawable/bg_field_input"
                                android:gravity="center"
                                android:inputType="number"
                                android:padding="8dp"
                                android:text="0"
                                android:textColor="#1A1A1A"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:background="@drawable/bg_inventory_card"
                            android:padding="16dp"
                            android:gravity="center"
                            android:layout_marginStart="6dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="B-"
                                android:textColor="#800000"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                            <EditText
                                android:id="@+id/etBNeg"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:background="@drawable/bg_field_input"
                                android:gravity="center"
                                android:inputType="number"
                                android:padding="8dp"
                                android:text="0"
                                android:textColor="#1A1A1A"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                    </LinearLayout>

                    <!-- Row 3: O+ and O- -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:background="@drawable/bg_inventory_card"
                            android:padding="16dp"
                            android:gravity="center"
                            android:layout_marginEnd="6dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="O+"
                                android:textColor="#800000"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                            <EditText
                                android:id="@+id/etOPos"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:background="@drawable/bg_field_input"
                                android:gravity="center"
                                android:inputType="number"
                                android:padding="8dp"
                                android:text="0"
                                android:textColor="#1A1A1A"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:background="@drawable/bg_inventory_card"
                            android:padding="16dp"
                            android:gravity="center"
                            android:layout_marginStart="6dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="O-"
                                android:textColor="#800000"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                            <EditText
                                android:id="@+id/etONeg"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:background="@drawable/bg_field_input"
                                android:gravity="center"
                                android:inputType="number"
                                android:padding="8dp"
                                android:text="0"
                                android:textColor="#1A1A1A"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                    </LinearLayout>

                    <!-- Row 4: AB+ and AB- -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:background="@drawable/bg_inventory_card"
                            android:padding="16dp"
                            android:gravity="center"
                            android:layout_marginEnd="6dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="AB+"
                                android:textColor="#800000"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                            <EditText
                                android:id="@+id/etABPos"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:background="@drawable/bg_field_input"
                                android:gravity="center"
                                android:inputType="number"
                                android:padding="8dp"
                                android:text="0"
                                android:textColor="#1A1A1A"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:background="@drawable/bg_inventory_card"
                            android:padding="16dp"
                            android:gravity="center"
                            android:layout_marginStart="6dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="AB-"
                                android:textColor="#800000"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                            <EditText
                                android:id="@+id/etABNeg"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:background="@drawable/bg_field_input"
                                android:gravity="center"
                                android:inputType="number"
                                android:padding="8dp"
                                android:text="0"
                                android:textColor="#1A1A1A"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 24H Operations Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="20dp"
                    android:paddingVertical="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:text="24-Hour Operations"
                        android:textColor="#1A1A1A"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/sw24Hours"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        app:useMaterialThemeColors="false"
                        app:thumbTint="#FFFFFF"
                        app:trackTint="#800000" />

                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <!-- Save Button -->
            <Button
                android:id="@+id/btnSaveBank"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:backgroundTint="#800000"
                android:text="Add new Blood Bank"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="12dp" />

        </LinearLayout>
    </ScrollView>

</RelativeLayout>
