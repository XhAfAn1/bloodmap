<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="0dp"
    android:layout_marginBottom="0dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header: Blood Type + Status Badge -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:textColor="#800000"
                android:textSize="22sp"
                android:textStyle="bold"
                tools:text="O+ RESPONSE"
                android:layout_marginEnd="8dp" />


        </RelativeLayout>

        <!-- Patient Info -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PATIENT"
            android:textColor="#BDBDBD"
            android:textSize="9sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvPatientDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#1A1A1A"
            android:textSize="14sp"
            tools:text="Patient: Azizullah • 25 Yrs • Male"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <!-- Hospital Info Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">
            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_admin_location_bold"
                app:tint="#800000" />
            <TextView
                android:id="@+id/tvHospital"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:textColor="#555555"
                tools:text="Birdem Hospital, Shahbagh"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Notes Container -->
        <LinearLayout
            android:id="@+id/layoutNotesContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F0F0F0"
                android:layout_marginBottom="12dp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="REQUESTER NOTES"
                android:textColor="#BDBDBD"
                android:textSize="9sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:layout_marginBottom="4dp" />
            <TextView
                android:id="@+id/tvNotes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#757575"
                tools:text="Please bring donor card."
                android:textSize="13sp"
                android:layout_marginBottom="12dp" />
        </LinearLayout>

        <!-- Status Message Section -->
        <LinearLayout
            android:id="@+id/layoutStatusMessageContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp"
            android:background="#FFF9F0"
            android:layout_marginBottom="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LIVE STATUS"
                android:textColor="#F57F17"
                android:textSize="8sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />
            <TextView
                android:id="@+id/tvStatusMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#F57F17"
                tools:text="Waiting for approval..."
                android:textStyle="bold"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Footer: Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnWithdraw"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Withdraw"
                android:textColor="#888888"
                app:strokeColor="#DDDDDD"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:paddingHorizontal="16dp"
                android:layout_marginEnd="8dp"
                app:cornerRadius="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNavigateResponse"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:backgroundTint="#800000"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:paddingHorizontal="16dp"
                android:text="Navigate"
                app:icon="@android:drawable/ic_menu_directions"
                app:iconGravity="textStart"
                app:iconSize="14dp"
                app:cornerRadius="8dp" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
