<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="0dp"
    android:layout_marginBottom="14dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header: Blood Type + Urgency -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:textColor="#800000"
                android:textSize="22sp"
                android:textStyle="bold"
                tools:text="O+ Blood Request"
                android:layout_toStartOf="@+id/tvUrgency"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tvUrgency"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:paddingHorizontal="12dp"
                android:paddingVertical="5dp"
                android:background="@drawable/bg_badge_red"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                tools:text="URGENT"
                android:textSize="9sp"
                android:letterSpacing="0.04" />
        </RelativeLayout>

        <!-- Patient Info -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PATIENT"
            android:textColor="#BDBDBD"
            android:textSize="9sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvPatientDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#1A1A1A"
            android:textSize="14sp"
            tools:text="Patient: Azizullah • 25 Yrs • Male"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <!-- Reason -->
        <TextView
            android:id="@+id/tvReason"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#757575"
            tools:text="Reason: Major surgery required immediately"
            android:textSize="13sp"
            android:layout_marginBottom="4dp" />

        <!-- Hospital Info Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="6dp">
            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_admin_location_bold"
                app:tint="#800000" />
            <TextView
                android:id="@+id/tvHospital"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:textColor="#555555"
                tools:text="United Hospital, Gulshan"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Time -->
        <TextView
            android:id="@+id/tvTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FF0000"
            tools:text="Needed by: 2026-04-20 10:30 AM"
            android:textSize="13sp"
            android:layout_marginBottom="12dp" />

        <!-- Notes Container -->
        <LinearLayout
            android:id="@+id/layoutNotesContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F0F0F0"
                android:layout_marginBottom="12dp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ADDITIONAL INFO"
                android:textColor="#BDBDBD"
                android:textSize="9sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:layout_marginBottom="4dp" />
            <TextView
                android:id="@+id/tvNotes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#757575"
                tools:text="Please contact if you are available."
                android:textSize="13sp"
                android:layout_marginBottom="12dp" />
        </LinearLayout>

        <!-- Divider before footer -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F0F0F0"
            android:layout_marginBottom="14dp" />

        <!-- Status Message Container -->
        <LinearLayout
            android:id="@+id/layoutStatusMessageContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="12dp"
            android:visibility="gone">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LIVE STATUS"
                android:textColor="#2E7D32"
                android:textSize="8sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />
            <TextView
                android:id="@+id/tvStatusMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#2E7D32"
                android:textStyle="bold"
                android:textSize="12sp"
                tools:text="Request Active" />
        </LinearLayout>

        <!-- Footer: Response Count + Manage Button -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RESPONSES"
                    android:textColor="#BDBDBD"
                    android:textSize="8sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05" />
                <TextView
                    android:id="@+id/tvResponsesCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#800000"
                    android:textStyle="bold"
                    tools:text="5 Responses"
                    android:textSize="14sp" />
            </LinearLayout>

            <Button
                android:id="@+id/btnManage"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:backgroundTint="#800000"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:paddingHorizontal="24dp"
                android:letterSpacing="0.04"
                android:text="Manage"
                app:cornerRadius="8dp" />
        </RelativeLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
